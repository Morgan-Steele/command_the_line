[sub_resource type="GDScript" id="GDScript_dfa4v"]
resource_name = "Orc"
script/source = "class_name Orc extends Enemy
#Orc has a lot of health and deals a lot of damage, but takes a while to wind up attack
@onready var _animated_sprite = $AnimatedSprite2D
var is_dead = false
func _physics_process(delta: float) -> void:
	if is_dead:
		return
	if not is_on_floor():
		velocity += get_gravity() * delta
	move_and_slide()

func _ready() -> void:
	health = 100
	damage = 25
	armor = 10
	speed = 20
	_animated_sprite.play(\"Idle\")

func take_damage(amount: int, attack_roll: int) -> void:
	if attack_roll >= armor:
		health -= amount
		if health <= 0:
			await die()
			StatsManager.in_combat = false

func die():
	is_dead = true
	print(\"Orc Dies\")
	_animated_sprite.play(\"death\")
	await get_tree().create_timer(1.5).timeout
	print(\"Orc Dead\")
	queue_free()
	

func attack() -> int:
	print(\"Orc attacked\")
	_animated_sprite.play(\"Attack\")
	await get_tree().create_timer(1.5).timeout
	var actual_damage = 0
	var offset = randi_range(-5,5)
	actual_damage = damage + offset
	_animated_sprite.play(\"Idle\")
	StatsManager.combat_desc = \"Orc attacked, doing \" + str(actual_damage) + \" damage!\\n\"
	return actual_damage

func defend() -> int:
	return armor
	
func heal() -> int:
	var total_damage = 100 - health
	var healthIncrease = total_damage * .1
	health += healthIncrease
	StatsManager.combat_desc = \"Orc healed a total of \" + str(healthIncrease) + \" points!\\n\"
	return health
	
func unique_move() -> void:
	StatsManager.combat_desc = \"Orc fumbles and loses a full turn!\\n\"

func _on_area_2d_body_entered(body: Node2D) -> void:
	if body.name == \"Player\":
		StatsManager.in_combat = true
		CombatManager.start_combat(self)
"

